# ── Domains (point all three A records to your VPS IP before starting) ──
LIVEKIT_DOMAIN=livekit.yourdomain.com
APP_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com

# ── LiveKit self-hosted ──────────────────────────────────────────────────
# Use any random strings — minimum 32 chars for the secret
LIVEKIT_URL=wss://livekit.yourdomain.com
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=changeme_use_a_long_random_secret_here_32chars

# ── AI Providers ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DEEPGRAM_API_KEY=...
CARTESIA_API_KEY=...

# ── SIP / Phone calling (optional — Twilio SIP trunk) ────────────────────
SIP_TRUNK_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com
NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.yourdomain.com

# Next.js token route keys (same as LiveKit keys above)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=changeme_use_a_long_random_secret_here_32chars
