# Caddy reverse proxy — auto-obtains Let's Encrypt SSL certs
# All three domains must have DNS A records pointing to this VPS before `docker compose up`.

# LiveKit signaling (WebSocket + HTTP API)
{$LIVEKIT_DOMAIN} {
    reverse_proxy livekit:7880 {
        transport http {
            dial_timeout 10s
            response_header_timeout 0
        }
    }
    header {
        -Server
    }
}

# Next.js frontend
{$APP_DOMAIN} {
    reverse_proxy frontend:3000
}

# Go backend API
{$API_DOMAIN} {
    reverse_proxy backend:8000
}
